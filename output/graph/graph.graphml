  <data key="d0">equation</data>
  <data key="d1">N/A</data>
  <data key="d2">1</data>
  <data key="d3">K ℓ ≤ t ∈ R t × d h , V ℓ ≤ t ∈ R t × d h , (2)</data>
  <data key="d4">0.8</data>
  <data key="d5">0.0</data>
  <data key="d6">705.4935302734375</data>
  <data key="d7">3f4c7190fe02</data>
  <data key="d8">True</data>
</node>
