<node id="e8d327303dfc">
  <data key="d0">caption</data>
  <data key="d1">Dataset</data>
  <data key="d2">2</data>
  <data key="d3">Table 2. RoPE similarity statistics on long-context QA benchmarks. We report Mean-of-Max (MoM) and Max scores across different inference strategies. Higher is better.</data>
  <data key="d4">0.8</data>
