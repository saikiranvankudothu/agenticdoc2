  <data key="d1">Method</data>
  <data key="d2">2</data>
  <data key="d3">Table 1. Ablation of RoPE geometry configurations on Qwen under the passage-split setting. Higher is better.</data>
  <data key="d4">0.8</data>
  <data key="d5">0.2571</data>
  <data key="d6">216.6430206298828</data>
  <data key="d7">60474b48521b</data>
  <data key="d8">False</data>
</node>
