          },
          "page_index": 1,
          "confidence": 0.8,
          "backend": "heuristic",
          "text_content": "Let the input consist of N tokens, which we partition into K disjoint chunks { C 1 , . . . , C K } . Each chunk serves as a basic unit for prefilling and can correspond to a naturally independent segment (e.g., a document or an image), or a contiguous partition of a single long input (e.g., a text sequence or a visual token grid).",
          "source_block_ids": [
            "14ee9cb6496a"
          ]
        },
        {
          "region_id": "4b772c40cc08",
          "region_class": "paragraph",
          "bbox": {
            "x0": 54.97200012207031,
