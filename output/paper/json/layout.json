            "y1": 320.05950927734375
          },
          "page_index": 0,
          "confidence": 0.8,
          "backend": "heuristic",
          "text_content": "tive information flow under the global causal attention graph.",
          "source_block_ids": [
            "aede1d4733a5"
          ]
        },
        {
          "region_id": "b5f5b80a2b1d",
          "region_class": "list",
