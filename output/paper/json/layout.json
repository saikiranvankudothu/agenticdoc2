            "y1": 632.2844848632812
          },
          "page_index": 1,
          "confidence": 0.8,
          "backend": "heuristic",
          "text_content": "where the head index is omitted for clarity.",
          "source_block_ids": [
            "fd5ad7dd566a"
          ]
        },
        {
          "region_id": "850faa696fff",
          "region_class": "paragraph",
          "bbox": {
            "x0": 55.439998626708984,
            "y0": 638.2125244140625,
            "x1": 291.097900390625,
            "y1": 698.0374755859375
          },
          "page_index": 1,
          "confidence": 0.8,
          "backend": "heuristic",
          "text_content": "During autoregressive decoding, to avoid recomputing keys and values for previously processed tokens, Transformer de- coders maintain a key–value (KV) cache that stores all past { k ℓ s , v ℓ s } s ≤ t at each layer. We denote the cached tensors up to position t by",
          "source_block_ids": [
            "95a233b098bc"
